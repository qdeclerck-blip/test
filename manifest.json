{
  "manifest_version": 3,
  "name": "ImmoTracker",
  "version": "1.0.0",
  "description": "Suivez et analysez vos biens immobiliers depuis Immoweb",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.immoweb.be/fr/annonce/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
